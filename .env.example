# ============================================================
#  PasarGuard-for-singbox — Environment
#  Copy to .env and edit before starting:
#    cp .env.example .env
# ============================================================

# --- Database ---
# SQLite (default, zero config):
SQLALCHEMY_DATABASE_URL=sqlite+aiosqlite:///db.sqlite3
# PostgreSQL (uncomment for production):
# SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/pasarguard

# --- Admin ---
# Change immediately after first login!
SUDO_USERNAME=admin
SUDO_PASSWORD=admin

# --- Server ---
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1

# --- Subscription ---
SUBSCRIPTION_PATH=sub

# --- Features ---
WIREGUARD_ENABLED=true
ROLE=all-in-one

# --- Node API key ---
# Must be a UUID. Generate one with: python3 -c "import uuid;print(uuid.uuid4())"
# This key must match what the node container uses.
API_KEY=
